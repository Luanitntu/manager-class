// ============================================================
// Schedule Teacher — Multi-tenant LMS for language teachers
// ============================================================
// Tenancy rule: every business entity belongs to a Teacher
// (User with role TEACHER). `teacherId` is the tenant key and
// must be filtered on every query. Teacher A must never read
// Teacher B's data.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------------
// Enums
// ------------------------------------------------------------

enum Role {
  SUPER_ADMIN
  TEACHER
  ASSISTANT
  STUDENT
}

enum UserStatus {
  PENDING
  ACTIVE
  LOCKED
}

enum SalaryMethod {
  PER_SESSION
  PER_HOUR
  PER_CLASS
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum EnrollmentStatus {
  ACTIVE
  INACTIVE
  COMPLETED
}

enum DocumentType {
  PDF
  MP3
  LINK
}

enum DocumentTargetType {
  STUDENT
  CLASS
}

enum PaymentStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  OVERDUE
}

enum ScoreType {
  MIDTERM
  FINAL
  ASSIGNMENT
  QUIZ
  CUSTOM
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

// ------------------------------------------------------------
// Identity & Auth
// ------------------------------------------------------------

model User {
  id            String     @id @default(uuid()) @db.Uuid
  email         String     @unique
  username      String?    @unique
  passwordHash  String     @map("password_hash")
  role          Role
  status        UserStatus @default(ACTIVE)
  fullName      String     @map("full_name")
  phone         String?
  avatarUrl     String?    @map("avatar_url")
  emailVerified Boolean    @default(false) @map("email_verified")

  // Tenancy: assistants & students belong to a teacher.
  // Null for SUPER_ADMIN and TEACHER (a teacher is their own tenant root).
  teacherId String? @map("teacher_id") @db.Uuid
  teacher   User?   @relation("TenantMembers", fields: [teacherId], references: [id], onDelete: Cascade)
  members   User[]  @relation("TenantMembers")

  // Profiles (role-specific extensions)
  assistantProfile AssistantProfile?
  studentProfile   StudentProfile?

  // Auth-related
  refreshTokens RefreshToken[]
  authTokens    AuthToken[]

  // Domain relations (as a teacher / tenant owner)
  ownedClasses    Class[]            @relation("TeacherClasses")
  ownedSessions   TeachingSession[]  @relation("TeacherSessions")
  ownedDocuments  Document[]         @relation("TeacherDocuments")
  ownedPayments   Tuition[]          @relation("TeacherTuitions")
  ownedScores     Score[]            @relation("TeacherScores")
  auditLogs       AuditLog[]         @relation("TenantAuditLogs")

  // Domain relations (as a student)
  enrollments       ClassEnrollment[]
  studentScores     Score[]           @relation("StudentScores")
  studentComments   StudentComment[]  @relation("StudentComments")
  studentTuitions   Tuition[]         @relation("StudentTuitions")
  studentDocuments  DocumentAssignment[] @relation("StudentDocuments")
  submittedEvals    Evaluation[]      @relation("StudentEvaluations")

  // Domain relations (as an assistant)
  classAssignments   ClassAssistant[]
  sessionAssignments SessionAssistant[]

  // Audit actor
  actorAuditLogs AuditLog[] @relation("ActorAuditLogs")
  authoredComments StudentComment[] @relation("AuthorComments")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([teacherId])
  @@index([role])
  @@map("users")
}

model AssistantProfile {
  id            String       @id @default(uuid()) @db.Uuid
  userId        String       @unique @map("user_id") @db.Uuid
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  salaryMethod  SalaryMethod @default(PER_SESSION) @map("salary_method")
  salaryRate    Decimal      @default(0) @map("salary_rate") @db.Decimal(12, 2)
  bio           String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("assistant_profiles")
}

model StudentProfile {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @unique @map("user_id") @db.Uuid
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  address        String?
  dateOfBirth    DateTime? @map("date_of_birth")
  occupation     String?
  educationLevel String?   @map("education_level")
  learningGoal   String?   @map("learning_goal")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("student_profiles")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("refresh_tokens")
}

model AuthToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      TokenType
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId, type])
  @@map("auth_tokens")
}

// ------------------------------------------------------------
// Classes & Sessions (Calendar-first core)
// ------------------------------------------------------------

model Class {
  id          String  @id @default(uuid()) @db.Uuid
  teacherId   String  @map("teacher_id") @db.Uuid
  teacher     User    @relation("TeacherClasses", fields: [teacherId], references: [id], onDelete: Cascade)
  name        String
  description String?
  level       String?
  color       String? // calendar display color
  isActive    Boolean @default(true) @map("is_active")

  sessions    TeachingSession[]
  enrollments ClassEnrollment[]
  assistants  ClassAssistant[]
  tuitions    Tuition[]
  scores      Score[]
  documentAssignments DocumentAssignment[]

  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([teacherId])
  @@map("classes")
}

model ClassEnrollment {
  id        String           @id @default(uuid()) @db.Uuid
  classId   String           @map("class_id") @db.Uuid
  class     Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  studentId String           @map("student_id") @db.Uuid
  student   User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status    EnrollmentStatus @default(ACTIVE)
  enrolledAt DateTime        @default(now()) @map("enrolled_at")

  @@unique([classId, studentId])
  @@index([studentId])
  @@map("class_enrollments")
}

model ClassAssistant {
  id          String @id @default(uuid()) @db.Uuid
  classId     String @map("class_id") @db.Uuid
  class       Class  @relation(fields: [classId], references: [id], onDelete: Cascade)
  assistantId String @map("assistant_id") @db.Uuid
  assistant   User   @relation(fields: [assistantId], references: [id], onDelete: Cascade)
  assignedAt  DateTime @default(now()) @map("assigned_at")

  @@unique([classId, assistantId])
  @@index([assistantId])
  @@map("class_assistants")
}

model TeachingSession {
  id          String        @id @default(uuid()) @db.Uuid
  teacherId   String        @map("teacher_id") @db.Uuid
  teacher     User          @relation("TeacherSessions", fields: [teacherId], references: [id], onDelete: Cascade)
  classId     String        @map("class_id") @db.Uuid
  class       Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  startTime   DateTime      @map("start_time")
  endTime     DateTime      @map("end_time")
  lessonTopic String?       @map("lesson_topic")
  status      SessionStatus @default(SCHEDULED)
  notes       String?

  // Links recurring sessions generated from one bulk operation
  recurrenceGroupId String? @map("recurrence_group_id") @db.Uuid

  assistants SessionAssistant[]

  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([teacherId, startTime])
  @@index([classId])
  @@index([recurrenceGroupId])
  @@map("teaching_sessions")
}

model SessionAssistant {
  id          String          @id @default(uuid()) @db.Uuid
  sessionId   String          @map("session_id") @db.Uuid
  session     TeachingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  assistantId String          @map("assistant_id") @db.Uuid
  assistant   User            @relation(fields: [assistantId], references: [id], onDelete: Cascade)

  @@unique([sessionId, assistantId])
  @@index([assistantId])
  @@map("session_assistants")
}

// ------------------------------------------------------------
// Academic records
// ------------------------------------------------------------

model Score {
  id        String    @id @default(uuid()) @db.Uuid
  teacherId String    @map("teacher_id") @db.Uuid
  teacher   User      @relation("TeacherScores", fields: [teacherId], references: [id], onDelete: Cascade)
  studentId String    @map("student_id") @db.Uuid
  student   User      @relation("StudentScores", fields: [studentId], references: [id], onDelete: Cascade)
  classId   String    @map("class_id") @db.Uuid
  class     Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  type      ScoreType
  label     String?   // for CUSTOM scores
  value     Decimal   @db.Decimal(5, 2)
  maxValue  Decimal   @default(10) @map("max_value") @db.Decimal(5, 2)

  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([teacherId])
  @@index([studentId, classId])
  @@map("scores")
}

model StudentComment {
  id        String  @id @default(uuid()) @db.Uuid
  teacherId String  @map("teacher_id") @db.Uuid
  studentId String  @map("student_id") @db.Uuid
  student   User    @relation("StudentComments", fields: [studentId], references: [id], onDelete: Cascade)
  authorId  String  @map("author_id") @db.Uuid
  author    User    @relation("AuthorComments", fields: [authorId], references: [id], onDelete: Cascade)
  category  String? // attitude, strengths, weaknesses, progress
  content   String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([teacherId])
  @@index([studentId])
  @@map("student_comments")
}

// ------------------------------------------------------------
// Documents / Learning materials
// ------------------------------------------------------------

model Document {
  id          String       @id @default(uuid()) @db.Uuid
  teacherId   String       @map("teacher_id") @db.Uuid
  teacher     User         @relation("TeacherDocuments", fields: [teacherId], references: [id], onDelete: Cascade)
  title       String
  description String?
  type        DocumentType
  category    String?      // A1, A2, B1, B2 ...
  fileKey     String?      @map("file_key") // R2 object key for PDF/MP3
  url         String?      // for external LINK
  ownerId     String       @map("owner_id") @db.Uuid // creator (teacher or assistant)

  assignments DocumentAssignment[]

  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([teacherId])
  @@map("documents")
}

model DocumentAssignment {
  id         String             @id @default(uuid()) @db.Uuid
  documentId String             @map("document_id") @db.Uuid
  document   Document           @relation(fields: [documentId], references: [id], onDelete: Cascade)
  targetType DocumentTargetType @map("target_type")
  classId    String?            @map("class_id") @db.Uuid
  class      Class?             @relation(fields: [classId], references: [id], onDelete: Cascade)
  studentId  String?            @map("student_id") @db.Uuid
  student    User?              @relation("StudentDocuments", fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([documentId])
  @@index([classId])
  @@index([studentId])
  @@map("document_assignments")
}

// ------------------------------------------------------------
// Tuition & Payments
// ------------------------------------------------------------

model Tuition {
  id            String        @id @default(uuid()) @db.Uuid
  teacherId     String        @map("teacher_id") @db.Uuid
  teacher       User          @relation("TeacherTuitions", fields: [teacherId], references: [id], onDelete: Cascade)
  studentId     String        @map("student_id") @db.Uuid
  student       User          @relation("StudentTuitions", fields: [studentId], references: [id], onDelete: Cascade)
  classId       String        @map("class_id") @db.Uuid
  class         Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  totalAmount   Decimal       @map("total_amount") @db.Decimal(12, 2)
  paidAmount    Decimal       @default(0) @map("paid_amount") @db.Decimal(12, 2)
  status        PaymentStatus @default(PENDING)
  dueDate       DateTime?     @map("due_date")
  notes         String?

  payments PaymentRecord[]

  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([teacherId])
  @@index([studentId])
  @@map("tuitions")
}

model PaymentRecord {
  id            String   @id @default(uuid()) @db.Uuid
  tuitionId     String   @map("tuition_id") @db.Uuid
  tuition       Tuition  @relation(fields: [tuitionId], references: [id], onDelete: Cascade)
  amount        Decimal  @db.Decimal(12, 2)
  paidAt        DateTime @default(now()) @map("paid_at")
  method        String?  // cash, transfer, ...
  receiptNumber String   @unique @map("receipt_number")
  note          String?

  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tuitionId])
  @@map("payment_records")
}

// ------------------------------------------------------------
// Evaluations (student feedback)
// ------------------------------------------------------------

model Evaluation {
  id        String   @id @default(uuid()) @db.Uuid
  teacherId String   @map("teacher_id") @db.Uuid
  studentId String   @map("student_id") @db.Uuid
  student   User     @relation("StudentEvaluations", fields: [studentId], references: [id], onDelete: Cascade)
  classId   String?  @map("class_id") @db.Uuid
  rating    Int      // 1..5
  subject   String?  // teacher, class, course quality
  feedback  String?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([teacherId])
  @@map("evaluations")
}

// ------------------------------------------------------------
// Audit logs
// ------------------------------------------------------------

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  teacherId  String?  @map("teacher_id") @db.Uuid // tenant (null for super-admin actions)
  tenant     User?    @relation("TenantAuditLogs", fields: [teacherId], references: [id], onDelete: Cascade)
  actorId    String   @map("actor_id") @db.Uuid
  actor      User     @relation("ActorAuditLogs", fields: [actorId], references: [id], onDelete: Cascade)
  action     String   // e.g. CLASS_CREATED, SESSION_UPDATED
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  ipAddress  String?  @map("ip_address")
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([teacherId])
  @@index([actorId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}
