# ============================================================
# Application
# ============================================================
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:3000

# ============================================================
# Database (PostgreSQL)
# ============================================================
DATABASE_URL="postgresql://schedule:schedule@localhost:5432/schedule_teacher?schema=public"

# ============================================================
# Redis (BullMQ broker)
# Managed Redis (Upstash/Redis Cloud) must use maxmemory-policy = noeviction.
# Set REDIS_TLS=true for providers requiring TLS (rediss://).
# Set QUEUE_ENABLED=false to run with NO Redis in dev (email queue disabled).
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false
QUEUE_ENABLED=true

# ============================================================
# JWT
# ============================================================
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# ============================================================
# Email (Resend)
# ============================================================
RESEND_API_KEY=
EMAIL_FROM="Schedule Teacher <no-reply@example.com>"

# ============================================================
# File Storage (Cloudflare R2)
# ============================================================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=
