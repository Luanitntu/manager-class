{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"C:/code/manager-class/.codex/hooks/gsd-check-update.cmd\"",
            "commandWindows": "\"C:/code/manager-class/.codex/hooks/gsd-check-update.cmd\""
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"C:/code/manager-class/.codex/hooks/gsd-context-monitor.cmd\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"C:/code/manager-class/.codex/hooks/gsd-context-monitor.cmd\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"C:/code/manager-class/.codex/hooks/gsd-context-monitor.cmd\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
